# Vorratsmonster ENV-Variablen.
# Kopiere diese Datei nach .env.local und trage echte Werte ein.
# .env.local wird via .gitignore NIEMALS committed.
#
# Werte findest du im Supabase-Dashboard:
#   Project Settings → API → Project URL und anon public key
#
# Siehe docs/supabase-setup.md für die Erst-Einrichtung.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Optional: Sync-Layer komplett abschalten und auf v2-Verhalten zurückfallen.
# Default: Sync ist aktiv, sobald Login + ENV-Vars vorhanden sind.
# VITE_SYNC_ENABLED=false
